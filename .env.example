# Cloudflare Account ID (Found on your Cloudflare Dashboard homepage)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Cloudflare R2 API Tokens (Go to Cloudflare -> R2 -> Manage R2 API Tokens -> Create API Token)
# Select permissions: "Object Read & Write"
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# The name of the R2 bucket you created (default is gallery-images)
R2_BUCKET_NAME=gallery-images
